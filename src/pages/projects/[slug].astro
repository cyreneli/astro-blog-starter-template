---
import BaseHead from '../../components/BaseHead.astro';
import { projects } from '../../data/projects';

export function getStaticPaths() {
	return projects.map((project) => ({ params: { slug: project.slug }, props: { project } }));
}

const { project } = Astro.props;
const isLocalEditor = import.meta.env.DEV;
const galleryImages = project.images ?? [];
---

<!doctype html>
<html lang="zh-CN">
	<head><BaseHead title={`${project.title} · 林未`} description={project.intro} /></head>
	<body>
		<main class={project.color}>
			<nav><div class="nav-left"><button class="back-button" type="button" data-go-back aria-label="返回上一页">←</button><a class="brand" href="/">LIN WEI<span>.</span></a></div><a href="/portfolio-coaching">← 返回辅导项目</a></nav>
			<header>
				<p>{project.index} / {project.service}</p>
				<h1 data-edit-title>{project.title}</h1>
				{galleryImages.length || isLocalEditor ? (
					<section class="project-slider" data-carousel aria-label={`${project.title} 项目图片`}>
						<div class="slider-track" data-track>
							{galleryImages.map((image, index) => <img src={image} alt={`${project.title} 项目图 ${index + 1}`} loading={index === 0 ? 'eager' : 'lazy'} />)}
						</div>
						<div class="slider-controls">
							<button type="button" class="slider-button previous" data-previous aria-label="上一张图片">←</button>
							<div class="slider-dots" aria-label="图片分页">
								{galleryImages.map((_, index) => <button type="button" data-dot={index} aria-label={`查看第 ${index + 1} 张图片`} class:list={{ active: index === 0 }}></button>)}
							</div>
							<button type="button" class="slider-button slider-next" data-next aria-label="下一张图片">→</button>
						</div>
					</section>
				) : <div class="hero-art" aria-hidden="true"><span></span><i></i><b></b></div>}
				<p class="subtitle" data-edit-subtitle>{project.subtitle}</p>
			</header>

			<section class="lead result"><p class="label">简介</p><p data-edit-intro>{project.intro}</p></section>
			<section class="result"><p class="label">成果</p><p data-edit-result>{project.result}</p></section>
			<section class="mentor">
				<p class="label">项目辅导老师</p>
				<div>
					<h2 data-edit-mentor-name>Cyreneli</h2>
					<p data-edit-mentor-bio>毕业于伦敦艺术大学（MSc Creative Computing），拥有 5 年作品集辅导经验。擅长引导学生发散思维，并指导学生完成技术落地，包括 VR 与 Web 端网页交互。同时是一线科学可视化设计师，擅长 3D 动态视频制作。</p>
				</div>
			</section>
			<section class="next"><p>想让你的项目也被好好讲述？</p><a href="mailto:hello@example.com?subject=作品集辅导咨询">预约咨询 <span>↗</span></a></section>
			<footer><span>© 2026 LIN WEI</span><span>PROJECT TEMPLATE</span></footer>
			{isLocalEditor && <>
				<button class="editor-trigger" type="button" data-editor-open>编辑网站</button>
				<dialog class="local-editor" data-local-editor>
					<form method="dialog" data-editor-form>
						<div class="editor-heading"><p>LOCAL EDITOR</p><button type="button" data-editor-close aria-label="关闭编辑器">×</button></div>
						<label>项目名称<input name="title" required /></label>
						<label>副标题<input name="subtitle" /></label>
						<label>项目简介<textarea name="intro" rows="8"></textarea></label>
						<label>成果<textarea name="result" rows="4"></textarea></label>
						<label>导师姓名<input name="mentorName" /></label>
						<label>导师介绍<textarea name="mentorBio" rows="5"></textarea></label>
						<label>替换轮播图片 <small>可多选；保存后会替换当前全部图片。</small><input name="images" type="file" accept="image/*" multiple /></label>
						<div class="editor-actions"><button type="button" data-editor-reset>清除本地修改</button><button type="submit">保存修改</button></div>
					</form>
				</dialog>
			</>}
		</main>
	</body>
</html>

<style>
	:global(body) { background: #f4f4f4; color: #4d4d4d; } main { width: auto; max-width: 1440px; margin: auto; padding: 0 42px; } nav { display: flex; justify-content: space-between; padding: 28px 0; border-bottom: 1px solid; } nav a { color: inherit; text-decoration: none; font-size: 14px; }.brand { font-size: 16px; font-weight: 700; letter-spacing: -.05em; }.brand span { color: #ff5c35; } header { padding: 94px 0 0; } header > p, .label { margin: 0; font-size: 12px; letter-spacing: .08em; text-transform: uppercase; } h1 { max-width: 960px; margin: 24px 0 70px; font-size: clamp(58px, 9vw, 130px); line-height: .9; letter-spacing: -.085em; font-weight: 400; }.hero-art { position: relative; height: clamp(300px, 46vw, 590px); overflow: hidden; border: 1px solid; background: #d5e4e0; }.hero-art span, .hero-art i, .hero-art b { position: absolute; display: block; border: 2px solid #1d1d1b; }.hero-art span { width: 33%; aspect-ratio: 1; top: 16%; left: 22%; border-radius: 50%; background: #ff5c35; }.hero-art i { width: 36%; aspect-ratio: 1; right: 18%; bottom: 12%; background: #f3f0e9; transform: rotate(28deg); }.hero-art b { width: 9%; aspect-ratio: 1; top: 20%; right: 23%; border-radius: 50%; background: #f5c94b; }.blue .hero-art { background: #7195b8; }.blue .hero-art span { border-radius: 0; background: #f3f0e9; transform: rotate(21deg); }.blue .hero-art i { border-radius: 50%; background: #ff5c35; }.yellow .hero-art { background: #f5c94b; }.yellow .hero-art span { background: #d5e4e0; }.yellow .hero-art i { border-radius: 50%; background: #ff8165; }.subtitle { margin: 16px 0 0; font-size: 14px; }.lead { padding: 60px 0; }.lead p { max-width: 1440px; margin: 0 auto; font-size: 12px; line-height: 1.5; letter-spacing: 0; }.content-grid, .result { display: grid; grid-template-columns: 28% 1fr; padding: 35px 0 55px; border-top: 1px solid; }.content-grid > p:last-child, .result > p:last-child, ol { max-width: 620px; margin: 0; font-size: 20px; line-height: 1.55; } ol { padding-left: 25px; } li { padding-left: 12px; margin-bottom: 8px; }.next { padding: 155px 0; text-align: center; }.next p { margin: 0 0 17px; }.next a { color: inherit; text-decoration: none; border-bottom: 2px solid; font-size: clamp(37px, 5vw, 72px); letter-spacing: -.07em; }.next span { color: #ff5c35; } footer { display: flex; justify-content: space-between; padding: 22px 0 32px; border-top: 1px solid; font-size: 11px; letter-spacing: .06em; } @media (max-width: 720px) { main { padding: 0 18px; } header { padding-top: 72px; } h1 { margin-bottom: 45px; font-size: clamp(54px, 15vw, 85px); }.lead { padding: 60px 0; }.lead p { font-size: 12px; }.content-grid, .result { grid-template-columns: 1fr; gap: 18px; }.content-grid > p:last-child, .result > p:last-child, ol { font-size: 18px; }.next { padding: 100px 0; } footer { font-size: 9px; gap: 15px; } }
	.lead p,
	.content-grid > p:last-child,
	.result > p:last-child,
	ol { max-width: 1440px; font-size: 14px; }
	.mentor { display: grid; grid-template-columns: 28% 1fr; gap: 0; padding: 35px 0 55px; border-top: 1px solid; }
	.mentor h2 { margin: 0 0 14px; font-size: clamp(34px, 4vw, 58px); font-weight: 400; letter-spacing: -.07em; }
	.mentor div > p { max-width: 620px; margin: 0; font-size: 14px; line-height: 1.55; }
	.lead.result > .label { max-width: none; margin: 0; font-size: 12px; }
	@media (max-width: 720px) { .mentor { grid-template-columns: 1fr; gap: 18px; } }
	.project-slider { position: relative; overflow: hidden; border: 1px solid; background: #000; }
	.slider-track { display: flex; overflow-x: auto; scroll-snap-type: x mandatory; scrollbar-width: none; -ms-overflow-style: none; }
	.slider-track::-webkit-scrollbar { display: none; }
	.slider-track img { display: block; flex: 0 0 100%; width: 100%; aspect-ratio: 2.3 / 1; min-height: 300px; object-fit: cover; scroll-snap-align: start; border-radius: 0; }
	.slider-controls { display: grid; grid-template-columns: 1fr auto 1fr; align-items: center; padding: 12px; }
	.slider-button { width: 38px; height: 38px; border: 1px solid currentColor; border-radius: 50%; background: #f4f4f4; color: inherit; font-size: 20px; cursor: pointer; transition: background .2s, color .2s; }
	.slider-button:hover { background: #4d4d4d; color: #f4f4f4; }.previous { justify-self: start; }.next { justify-self: end; }
	.slider-dots { display: flex; align-items: center; gap: 7px; }.slider-dots button { width: 7px; height: 7px; padding: 0; border: 1px solid #4d4d4d; border-radius: 50%; background: transparent; cursor: pointer; transition: width .25s ease, border-radius .25s ease, background .25s ease; }.slider-dots button.active { width: 24px; border-radius: 999px; background: #4d4d4d; }
	@media (max-width: 720px) { .slider-track img { min-height: 220px; aspect-ratio: 1.25 / 1; }.slider-controls { padding: 9px; }.slider-button { width: 34px; height: 34px; } }
	.project-slider { padding-bottom: 48px; overflow: visible; }
	.slider-controls { position: static; padding: 0; }
	.slider-button { position: absolute; z-index: 2; top: calc(50% - 43px); }
	.previous { left: 16px; }.slider-next { right: 16px; }
	.slider-dots { position: absolute; bottom: 17px; left: 50%; transform: translateX(-50%); }
	@media (max-width: 720px) { .slider-button { top: calc(50% - 39px); }.previous { left: 10px; }.slider-next { right: 10px; } }
	.project-slider { width: 1440px; max-width: 100%; }
	.slider-track img { height: auto; min-height: 0; aspect-ratio: auto; object-fit: contain; }
	.slider-button.previous,
	.slider-button.slider-next { display: grid; place-items: center; padding: 1px; border-radius: 50%; }
	.nav-left { display: flex; align-items: center; gap: 13px; }.back-button { display: grid; place-items: center; width: 29px; height: 29px; padding: 0; border: 1px solid currentColor; border-radius: 50%; background: transparent; color: inherit; cursor: pointer; font-size: 16px; }.back-button:hover { background: #4d4d4d; color: #f4f4f4; }
	.project-slider, .slider-track, .slider-track img { border-radius: 0 !important; }
	.editor-trigger { position: fixed; right: 24px; bottom: 24px; z-index: 10; padding: 11px 16px; border: 1px solid #4d4d4d; border-radius: 999px; background: #4d4d4d; color: #f4f4f4; font-size: 13px; cursor: pointer; box-shadow: 0 7px 18px rgba(0,0,0,.14); }
	.local-editor { width: min(620px, calc(100% - 30px)); max-height: calc(100vh - 40px); padding: 0; border: 1px solid #4d4d4d; background: #f4f4f4; color: #4d4d4d; }.local-editor::backdrop { background: rgba(0,0,0,.42); }.local-editor form { display: grid; gap: 16px; padding: 24px; overflow-y: auto; }.editor-heading, .editor-actions { display: flex; justify-content: space-between; align-items: center; gap: 16px; }.editor-heading p { margin: 0; font-size: 12px; letter-spacing: .08em; }.editor-heading button { border: 0; background: transparent; font-size: 27px; cursor: pointer; }.local-editor label { display: grid; gap: 7px; font-size: 13px; }.local-editor small { color: #777; font-size: 11px; }.local-editor input, .local-editor textarea { width: 100%; box-sizing: border-box; padding: 10px; border: 1px solid #9b9b9b; border-radius: 0; background: #fff; color: #1d1d1b; font: inherit; }.local-editor textarea { resize: vertical; }.editor-actions { padding-top: 8px; }.editor-actions button { padding: 10px 14px; border: 1px solid #4d4d4d; background: transparent; color: inherit; cursor: pointer; }.editor-actions button[type='submit'] { background: #4d4d4d; color: #f4f4f4; }
</style>

<script>
	const setupCarousels = () => document.querySelectorAll<HTMLElement>('[data-carousel]').forEach((carousel) => {
		if (carousel.dataset.ready) return;
		carousel.dataset.ready = 'true';
		const track = carousel.querySelector<HTMLElement>('[data-track]');
		const previous = carousel.querySelector<HTMLButtonElement>('[data-previous]');
		const next = carousel.querySelector<HTMLButtonElement>('[data-next]');
		const dots = Array.from(carousel.querySelectorAll<HTMLButtonElement>('[data-dot]'));
		if (!track || !previous || !next || !dots.length) return;

		const goTo = (index: number) => track.scrollTo({ left: index * track.clientWidth, behavior: 'smooth' });
		const currentIndex = () => Math.round(track.scrollLeft / track.clientWidth);
		const updateDots = () => dots.forEach((dot, index) => dot.classList.toggle('active', index === currentIndex()));
		previous.addEventListener('click', () => goTo(Math.max(0, currentIndex() - 1)));
		next.addEventListener('click', () => goTo(Math.min(dots.length - 1, currentIndex() + 1)));
		dots.forEach((dot, index) => dot.addEventListener('click', () => goTo(index)));
		track.addEventListener('scroll', updateDots, { passive: true });
		let wheelLocked = false;
		carousel.addEventListener('wheel', (event) => {
			if (Math.abs(event.deltaY) <= Math.abs(event.deltaX) || wheelLocked) return;
			event.preventDefault();
			wheelLocked = true;
			goTo(Math.max(0, Math.min(dots.length - 1, currentIndex() + (event.deltaY > 0 ? 1 : -1))));
			window.setTimeout(() => { wheelLocked = false; }, 420);
		}, { passive: false });
	});
	document.querySelector<HTMLButtonElement>('[data-go-back]')?.addEventListener('click', () => {
		if (window.history.length > 1) window.history.back();
		else window.location.href = '/portfolio-projects';
	});

	const editor = document.querySelector<HTMLDialogElement>('[data-local-editor]');
	if (!editor) {
		setupCarousels();
	} else {
		const projectKey = `local-project:${window.location.pathname}`;
		const openDatabase = () => new Promise<IDBDatabase>((resolve, reject) => {
			const request = indexedDB.open('portfolio-local-editor', 1);
			request.onupgradeneeded = () => request.result.createObjectStore('projects');
			request.onsuccess = () => resolve(request.result);
			request.onerror = () => reject(request.error);
		});
		const getRecord = async () => {
			const database = await openDatabase();
			return await new Promise<any>((resolve, reject) => {
				const request = database.transaction('projects').objectStore('projects').get(projectKey);
				request.onsuccess = () => resolve(request.result);
				request.onerror = () => reject(request.error);
			});
		};
		const saveRecord = async (record: any) => {
			const database = await openDatabase();
			await new Promise<void>((resolve, reject) => {
				const request = database.transaction('projects', 'readwrite').objectStore('projects').put(record, projectKey);
				request.onsuccess = () => resolve(); request.onerror = () => reject(request.error);
			});
		};
		const deleteRecord = async () => {
			const database = await openDatabase();
			await new Promise<void>((resolve, reject) => {
				const request = database.transaction('projects', 'readwrite').objectStore('projects').delete(projectKey);
				request.onsuccess = () => resolve(); request.onerror = () => reject(request.error);
			});
		};
		const fields = {
			title: '[data-edit-title]', subtitle: '[data-edit-subtitle]', intro: '[data-edit-intro]', result: '[data-edit-result]',
			mentorName: '[data-edit-mentor-name]', mentorBio: '[data-edit-mentor-bio]',
		};
		const applyRecord = (record: any) => {
			if (!record) return;
			Object.entries(fields).forEach(([key, selector]) => {
				const element = document.querySelector<HTMLElement>(selector);
				if (element && record.fields?.[key]) element.textContent = record.fields[key];
			});
			if (!record.images?.length) return;
			const track = document.querySelector<HTMLElement>('[data-track]');
			const dots = document.querySelector<HTMLElement>('.slider-dots');
			if (!track || !dots) return;
			track.innerHTML = record.images.map((source: string, index: number) => `<img src="${source}" alt="项目图 ${index + 1}">`).join('');
			dots.innerHTML = record.images.map((_: string, index: number) => `<button type="button" data-dot="${index}" aria-label="查看第 ${index + 1} 张图片" class="${index === 0 ? 'active' : ''}"></button>`).join('');
		};
		const fileToDataUrl = (file: File) => new Promise<string>((resolve, reject) => {
			const reader = new FileReader(); reader.onload = () => resolve(String(reader.result)); reader.onerror = () => reject(reader.error); reader.readAsDataURL(file);
		});
		const form = editor.querySelector<HTMLFormElement>('[data-editor-form]')!;
		const fillForm = () => Object.entries(fields).forEach(([key, selector]) => {
			const input = form.elements.namedItem(key) as HTMLInputElement | HTMLTextAreaElement;
			const element = document.querySelector<HTMLElement>(selector);
			if (input && element) input.value = element.textContent ?? '';
		});
		document.querySelector<HTMLButtonElement>('[data-editor-open]')?.addEventListener('click', () => { fillForm(); editor.showModal(); });
		editor.querySelector<HTMLButtonElement>('[data-editor-close]')?.addEventListener('click', () => editor.close());
		editor.querySelector<HTMLButtonElement>('[data-editor-reset]')?.addEventListener('click', async () => { await deleteRecord(); window.location.reload(); });
		form.addEventListener('submit', async (event) => {
			event.preventDefault();
			const formData = new FormData(form);
			const current = await getRecord();
			const imageFiles = formData.getAll('images').filter((file): file is File => file instanceof File && file.size > 0);
			await saveRecord({
				fields: Object.fromEntries(Object.keys(fields).map((key) => [key, String(formData.get(key) ?? '')])),
				images: imageFiles.length ? await Promise.all(imageFiles.map(fileToDataUrl)) : current?.images,
			});
			window.location.reload();
		});
		getRecord().then((record) => { applyRecord(record); setupCarousels(); }).catch(() => setupCarousels());
	}
</script>
