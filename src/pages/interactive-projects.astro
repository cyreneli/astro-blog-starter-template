---
import BaseHead from '../components/BaseHead.astro';
import ProjectCollection from '../components/ProjectCollection.astro';
import { projects } from '../data/projects';

const collection = projects.filter((project) => project.slug === 'interactive-archive-prototype');
---

<!doctype html>
<html lang="zh-CN"><head><BaseHead title="交互技术制作项目 · Cyrene 文无" description="交互技术制作项目陈列" /></head><body><ProjectCollection title="交互技术制作" eyebrow="INTERACTIVE PROTOTYPING / SELECTED WORK" intro="将研究、概念与叙事转化为可以被体验和探索的数字原型。" backHref="/portfolio-coaching" projects={collection} editableKey="interactive" /></body></html>
