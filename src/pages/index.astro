---
import BaseHead from '../components/BaseHead.astro';
---

<!doctype html>
<html lang="zh-CN">
	<head>
		<BaseHead
			title="Cyrene 文无 · Interdisciplinary Designer"
			description="Cyrene 文无，一名常驻杭州的跨学科设计师。"
		/>
	</head>
	<body>
		<main>
			<header class="site-header">
				<a class="brand" href="/">Cyrene 文无</a>
				<nav aria-label="主导航">
					<a href="/portfolio-coaching">Case <span>案例</span></a>
					<a href="#about">Me <span>我</span></a>
					<a href="/contact">Contact <span>联系</span></a>
				</nav>
			</header>

			<section class="hero" id="about" aria-labelledby="hero-title">
				<h1 id="hero-title">Hi&nbsp; I am Cyrene 文无</h1>
				<div class="introduction">
					<p lang="en">
						I’m an interdisciplinary <strong>designer</strong> living in <strong>HangZhou</strong>,
						creating visual narratives that make life sciences accessible and engaging at
						<strong>Omoolab</strong>.
					</p>
					<p>
						我是一名base在<strong>杭州</strong>的跨学科<strong>设计师</strong>，现在在
						<strong>Omoolab</strong> 工作，通过视觉叙事让<strong>生命科学</strong>变得更易理解、更具吸引力。
					</p>
				</div>
			</section>

			<section class="pathways" aria-label="服务方向">
				<a class="path-card designer" href="mailto:hello@example.com?subject=独立设计师合作">
					<h2>独立设计师</h2>
				</a>
				<a class="path-card coaching" href="/portfolio-coaching">
					<h2>作品集辅导</h2>
				</a>
			</section>
		</main>
	</body>
</html>

<style>
	:global(html) {
		background: #2c2c2c !important;
	}

	:global(body) {
		margin: 0;
		background: #2c2c2c !important;
		color: #f4f4f4 !important;
		font-family: Futura, 'Futura PT', 'Helvetica Neue', Arial, sans-serif;
	}

	main {
		position: relative;
		box-sizing: border-box;
		min-height: 100svh;
		width: 100%;
		max-width: none;
		margin: 0 auto;
		padding: 70px 10.15vw 0;
		overflow: hidden;
	}

	.site-header {
		position: relative;
		z-index: 2;
		display: flex;
		align-items: center;
		justify-content: space-between;
		margin-right: -4.8vw;
	}

	.brand,
	nav a {
		color: #f2f2f2;
		font-size: 24px;
		font-weight: 400;
		line-height: 1;
		text-decoration: none;
		letter-spacing: -0.04em;
	}

	nav {
		display: flex;
		gap: clamp(30px, 5.9vw, 90px);
	}

	nav a {
		color: #6f6f6f;
		transition: color 180ms ease;
	}

	nav a:hover,
	nav a:focus-visible {
		color: #f4f4f4;
	}

	.hero {
		position: relative;
		z-index: 1;
		padding-top: clamp(180px, 18.6vw, 270px);
	}

	h1 {
		margin: 0;
		color: #f4f4f4;
		font-size: clamp(42px, 4.05vw, 61px);
		font-weight: 400;
		line-height: 1.08;
		letter-spacing: -0.055em;
	}

	.introduction {
		max-width: 835px;
		margin-top: 52px;
		color: #707070;
		font-size: clamp(23px, 2.08vw, 30px);
		font-weight: 400;
		line-height: 1.33;
		letter-spacing: -0.045em;
	}

	.introduction p {
		margin: 0;
	}

	.introduction p + p {
		margin-top: 38px;
	}

	.introduction strong {
		color: #f2f2f2;
		font-weight: 400;
	}

	.pathways {
		--circle-size: clamp(260px, 30.4vw, 520px);
		display: grid;
		grid-template-columns: repeat(2, var(--circle-size));
		justify-content: start;
		gap: clamp(80px, 18.4vw, 290px);
		margin-top: clamp(130px, 10.6vw, 154px);
		padding: 0 0 170px 4px;
	}

	.path-card {
		position: relative;
		display: grid;
		place-items: center;
		box-sizing: border-box;
		width: var(--circle-size);
		height: var(--circle-size);
		padding: 0;
		border: 0;
		border-radius: 50%;
		color: #f4f4f4;
		text-decoration: none;
		overflow: hidden;
		transition: transform 220ms ease, background-color 220ms ease;
	}

	.path-card:hover,
	.path-card:focus-visible {
		background: #313131;
		transform: scale(1.045);
	}

	.designer {
		background: #202020;
	}

	.coaching {
		background: #202020;
	}

	.path-card h2 {
		margin: 0;
		color: #f4f4f4;
		font-size: 52px;
		font-weight: 400;
		line-height: 1.1;
		letter-spacing: -0.06em;
	}

	@media (min-width: 900px) {
		main {
			min-height: 1456px;
		}
	}

	@media (max-width: 720px) {
		main {
			padding-top: 30px;
			padding-inline: 24px;
		}

		.brand,
		nav a {
			font-size: 16px;
		}

		.site-header {
			margin-right: 0;
		}

		nav {
			gap: 16px;
		}

		nav a span {
			display: none;
		}

		.hero {
			padding-top: 124px;
		}

		.introduction {
			font-size: clamp(20px, 6vw, 28px);
			line-height: 1.38;
		}

		.introduction p + p {
			margin-top: 30px;
		}

		.pathways {
			grid-template-columns: 1fr;
			justify-items: center;
			margin-top: 82px;
			padding-bottom: 48px;
		}

		.path-card {
			width: min(78vw, 360px);
			height: auto;
			aspect-ratio: 1;
		}

		.path-card h2 {
			font-size: clamp(36px, 10vw, 48px);
		}
	}
</style>
