---
import BaseHead from '../components/BaseHead.astro';
---

<!doctype html>
<html lang="zh-CN">
	<head>
		<BaseHead title="林未 · Independent Designer" description="林未的独立设计与作品集辅导" />
	</head>
	<body>
		<main>
			<nav class="nav" aria-label="主导航">
				<a class="wordmark" href="/">LIN WEI<span>.</span></a>
				<div class="nav-links">
					<a href="#work">作品</a>
					<a href="#contact">联系</a>
				</div>
			</nav>

			<section class="hero" aria-labelledby="intro-title">
				<p class="eyebrow">上海 / 可远程合作</p>
				<h1 id="intro-title">你好，我是林未。<br />我用设计，让想法<span>被看见。</span></h1>
				<div class="intro-grid">
					<p>
						一名关注品牌、数字体验与视觉叙事的独立设计师。相信好的设计不只解决问题，也让人愿意停下来感受。
					</p>
					<a class="round-link" href="#paths" aria-label="探索我的服务">↘</a>
				</div>
			</section>

			<section class="paths" id="paths" aria-label="服务方向">
				<a class="path-card design-card" id="work" href="mailto:hello@example.com?subject=独立设计合作">
					<div class="card-top"><span>01</span><span>品牌 / 数字体验</span></div>
					<div class="card-content">
						<p class="card-label">For brands &amp; founders</p>
						<h2>独立设计师</h2>
						<p class="card-copy">从策略到落地，为有想法的品牌打造清晰、有温度的视觉语言与数字体验。</p>
						<span class="card-cta">查看合作方式 <b>↗</b></span>
					</div>
					<div class="shape shape-one"></div><div class="shape shape-two"></div>
				</a>

				<a class="path-card mentor-card" href="/portfolio-coaching">
					<div class="card-top"><span>02</span><span>1:1 / 小班制</span></div>
					<div class="card-content">
						<p class="card-label">For emerging creatives</p>
						<h2>作品集辅导</h2>
						<p class="card-copy">陪你梳理方向、打磨项目，让每一页作品都更有说服力，也更像你自己。</p>
						<span class="card-cta">了解辅导计划 <b>↗</b></span>
					</div>
					<div class="orbit"><i></i><i></i><i></i></div>
				</a>
			</section>

			<section class="closing" id="contact">
				<p>有一个值得开始的想法？</p>
				<a href="mailto:hello@example.com">hello@example.com <span>↗</span></a>
			</section>

			<footer><span>© 2026 LIN WEI</span><span>DESIGNED WITH CURIOSITY</span></footer>
		</main>
	</body>
</html>

<style>
	:global(body) { background: #f4f4f4; color: #1d1d1b; }
	main { width: auto; max-width: 1440px; margin: 0 auto; padding: 0 42px; }
	.nav { display: flex; justify-content: space-between; align-items: center; padding: 28px 0; border-bottom: 1px solid #1d1d1b; }
	.wordmark { font-size: 16px; font-weight: 700; letter-spacing: -.05em; color: inherit; text-decoration: none; }
	.wordmark span { color: #ff5c35; }
	.nav-links { display: flex; gap: 26px; }
	.nav-links a { color: inherit; text-decoration: none; font-size: 14px; }
	.hero { padding: clamp(86px, 13vw, 190px) 0 92px; }
	.eyebrow, .card-label { margin: 0; text-transform: uppercase; letter-spacing: .08em; font-size: 12px; }
	h1 { max-width: 1100px; margin: 24px 0 0; font-size: clamp(51px, 7.6vw, 110px); letter-spacing: -.075em; line-height: .98; font-weight: 400; }
	h1 span { color: #ff5c35; font-style: italic; }
	.intro-grid { display: flex; align-items: end; justify-content: space-between; gap: 30px; max-width: 720px; margin: 64px 0 0 auto; }
	.intro-grid p { max-width: 460px; margin: 0; font-size: 18px; line-height: 1.55; }
	.round-link { display: grid; place-items: center; flex: 0 0 54px; height: 54px; border: 1px solid #1d1d1b; border-radius: 50%; color: inherit; text-decoration: none; font-size: 25px; transition: .25s; }
	.round-link:hover { background: #1d1d1b; color: #f3f0e9; transform: rotate(45deg); }
	.paths { display: grid; grid-template-columns: repeat(2, 1fr); border: 1px solid #1d1d1b; }
	.path-card { position: relative; min-height: 550px; overflow: hidden; padding: 25px; color: #1d1d1b; text-decoration: none; isolation: isolate; }
	.path-card + .path-card { border-left: 1px solid #1d1d1b; }
	.design-card { background: #d5e4e0; }
	.mentor-card { background: #f5c94b; }
	.card-top { display: flex; justify-content: space-between; font-size: 12px; letter-spacing: .04em; }
	.card-content { position: absolute; z-index: 2; left: 25px; right: 25px; bottom: 28px; }
	.card-content h2 { margin: 11px 0; font-size: clamp(38px, 4.5vw, 64px); letter-spacing: -.075em; font-weight: 400; }
	.card-copy { width: min(370px, 88%); margin: 0 0 22px; font-size: 16px; line-height: 1.5; }
	.card-cta { display: inline-flex; gap: 24px; align-items: center; border-bottom: 1px solid currentColor; padding-bottom: 5px; font-size: 14px; }
	.card-cta b { font-size: 19px; font-weight: 400; }
	.shape { position: absolute; z-index: 1; border: 2px solid #1d1d1b; transition: transform .5s cubic-bezier(.2,.7,.2,1); }
	.shape-one { width: 230px; height: 230px; top: 80px; right: 15%; border-radius: 50%; background: #ff5c35; }
	.shape-two { width: 180px; height: 180px; top: 180px; right: 35%; background: #f3f0e9; transform: rotate(23deg); }
	.path-card:hover .shape-one { transform: scale(1.14); }.path-card:hover .shape-two { transform: rotate(-18deg) translate(-12px, -6px); }
	.orbit { position: absolute; top: 68px; left: 50%; width: 270px; height: 270px; transform: translateX(-50%) rotate(-25deg); border: 2px solid #1d1d1b; border-radius: 50%; transition: transform .6s ease; }
	.orbit:before, .orbit:after { content: ''; position: absolute; border: 2px solid #1d1d1b; border-radius: 50%; }
	.orbit:before { inset: 34px -52px; }.orbit:after { inset: 75px -95px; }
	.orbit i { position: absolute; display: block; width: 17px; height: 17px; border-radius: 50%; background: #ff5c35; }
	.orbit i:nth-child(1) { top: -10px; left: 48%; }.orbit i:nth-child(2) { bottom: 38px; right: -14px; background: #f3f0e9; border: 2px solid #1d1d1b; }.orbit i:nth-child(3) { left: -7px; bottom: 20px; background: #1d1d1b; }
	.path-card:hover .orbit { transform: translateX(-50%) rotate(25deg) scale(1.06); }
	.closing { display: flex; justify-content: space-between; align-items: end; padding: 130px 0; }
	.closing p { margin: 0; font-size: 16px; }.closing a { color: inherit; font-size: clamp(27px, 4vw, 52px); letter-spacing: -.05em; text-decoration: none; border-bottom: 2px solid; }.closing a span { color: #ff5c35; }
	footer { display: flex; justify-content: space-between; border-top: 1px solid #1d1d1b; padding: 22px 0 32px; font-size: 11px; letter-spacing: .06em; }
	@media (max-width: 720px) { main { padding: 0 18px; }.hero { padding: 76px 0; } h1 { font-size: clamp(45px, 14vw, 76px); }.intro-grid { margin-top: 42px; }.intro-grid p { font-size: 16px; }.paths { grid-template-columns: 1fr; }.path-card { min-height: 470px; }.path-card + .path-card { border-left: 0; border-top: 1px solid #1d1d1b; }.closing { display: block; padding: 88px 0; }.closing a { display: inline-block; margin-top: 17px; font-size: 29px; } footer { font-size: 9px; gap: 18px; } }
</style>
