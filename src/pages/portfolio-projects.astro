---
import BaseHead from '../components/BaseHead.astro';
import { projects } from '../data/projects';
const isLocalEditor = import.meta.env.DEV;
---

<!doctype html>
<html lang="zh-CN">
	<head><BaseHead title="作品集辅导项目 · 林未" description="作品集辅导项目陈列" /></head>
	<body>
		<main>
			<nav aria-label="主导航">
				<a class="brand" href="/">Cyrene 文无</a>
				<a class="active" href="/portfolio-coaching">Case <span>案例</span></a>
				<a href="/#about">Me <span>我</span></a>
				<a href="/contact">Contact <span>联系</span></a>
			</nav>
			<header><p>PORTFOLIO MENTORING / SELECTED WORK</p><h1>项目陈列</h1><p class="intro">每一份作品集，都始于不同的经验与问题。这里记录部分已经完成的辅导项目。</p></header>
			<section class="project-grid" aria-label="作品集辅导项目">
				{projects.map((project) => (
					<div class="project-card-wrap" data-project-card data-project-id={project.slug}>
						<a class:list={['project-card', project.color]} href={`/projects/${project.slug}`}>
							<div class="cover" aria-hidden="true">{project.images?.[0] ? <img src={project.images[0]} alt="" /> : <><i></i><b></b></>}<span>{project.index}</span></div>
							<div class="project-info"><h2>{project.title}</h2><div class="tags"><span>{project.school}</span><span>{project.major}</span><span>{project.term}</span></div><p>{project.summary}</p></div>
						</a>
						{isLocalEditor && <button class="card-edit" type="button" data-edit-card={project.slug} aria-label={`编辑 ${project.title}`}>编辑</button>}
					</div>
				))}
				{isLocalEditor && <button class="project-add-card" type="button" data-add-card aria-label="增加新的项目">＋</button>}
			</section>
			<section class="contact"><p>想成为下一个项目？</p><a href="mailto:hello@example.com?subject=作品集辅导咨询">预约咨询 <span>↗</span></a></section>
			<footer><span>© 2026 LIN WEI</span><span>SHANGHAI / REMOTE</span></footer>
			{isLocalEditor && <>
				<dialog class="local-editor" data-list-editor>
					<form data-list-editor-form>
						<div class="editor-heading"><p>PROJECT EDITOR</p><button type="button" data-list-editor-close aria-label="关闭编辑器">×</button></div>
						<label>选择项目<select name="projectId" data-project-select></select></label>
						<label>项目名称<input name="title" required /></label>
						<label>项目标签 <small>以逗号分隔，例如：伦敦艺术大学, 交互设计, 27FALL</small><input name="tags" /></label>
						<label>项目介绍<textarea name="summary" rows="5"></textarea></label>
						<label>项目封面<input name="cover" type="file" accept="image/*" /></label>
						<div class="editor-actions"><button type="button" data-delete-project>删除当前项目</button><button type="button" data-list-editor-reset>清除本地修改</button><button type="submit">保存修改</button></div>
					</form>
				</dialog>
			</>}
		</main>
	</body>
</html>

<style is:global>
	:global(body) { background: #f4f4f4; color: #1d1d1b; } main { width: auto; max-width: 1440px; margin: auto; padding: 0 42px; } nav { display: flex; justify-content: space-between; padding: 28px 0; border-bottom: 1px solid; } nav a { color: inherit; text-decoration: none; font-size: 14px; }.brand { font-size: 16px; font-weight: 700; letter-spacing: -.05em; }.brand span, .contact span { color: #ff5c35; } header { padding: clamp(80px, 12vw, 160px) 0 92px; } header > p:first-child { margin: 0; font-size: 12px; letter-spacing: .08em; } h1 { margin: 19px 0 47px; font-size: clamp(67px, 10vw, 145px); font-weight: 400; line-height: .86; letter-spacing: -.09em; }.intro { max-width: 490px; margin: 0 0 0 auto; font-size: 18px; line-height: 1.55; }.project-grid { display: grid; grid-template-columns: repeat(3, 1fr); border-top: 1px solid; }.project-card { padding: 18px; color: inherit; text-decoration: none; border-bottom: 1px solid; }.project-card + .project-card { border-left: 1px solid; }.cover { position: relative; height: clamp(220px, 26vw, 365px); overflow: hidden; border: 1px solid; }.cover i, .cover b { position: absolute; display: block; border: 2px solid #1d1d1b; transition: transform .45s cubic-bezier(.2,.7,.2,1); }.cover span { position: absolute; right: 13px; bottom: 8px; font-size: 12px; }.coral .cover { background: #ff8165; }.coral .cover i { width: 48%; aspect-ratio: 1; top: 18%; left: 17%; border-radius: 50%; background: #f5c94b; }.coral .cover b { width: 38%; aspect-ratio: 1; right: 12%; bottom: 13%; background: #f3f0e9; transform: rotate(24deg); }.blue .cover { background: #7195b8; }.blue .cover i { width: 54%; aspect-ratio: 1; top: 19%; left: 20%; background: #f3f0e9; transform: rotate(22deg); }.blue .cover b { width: 27%; aspect-ratio: 1; top: 14%; right: 15%; border-radius: 50%; background: #ff5c35; }.yellow .cover { background: #f5c94b; }.yellow .cover i { width: 63%; aspect-ratio: 1; top: 14%; left: 17%; border-radius: 50%; background: #d5e4e0; }.yellow .cover b { width: 30%; aspect-ratio: 1; right: 12%; bottom: 11%; border-radius: 50%; background: #ff8165; }.project-info { width: 100%; box-sizing: border-box; padding: 20px 0 6px; }.project-info h2 { min-height: 78px; margin: 0 0 16px; font-size: clamp(28px, 2.8vw, 41px); line-height: 1; letter-spacing: -.07em; font-weight: 400; }.tags { display: flex; flex-wrap: wrap; gap: 6px; }.tags span { padding: 4px 8px; border: 1px solid; border-radius: 20px; font-size: 10px; }.project-info p { width: 100%; margin: 17px 0 0; font-family: Futura, 'Futura PT', 'Trebuchet MS', sans-serif; font-size: 12px; line-height: 1.5; }.project-card:hover .cover i { transform: rotate(42deg) scale(1.12); }.project-card:hover .cover b { transform: rotate(-25deg) translate(-8px, -5px) scale(1.08); }.project-card:hover h2 { text-decoration: underline; text-decoration-thickness: 1px; text-underline-offset: 5px; }.contact { padding: 140px 0; text-align: center; }.contact p { margin: 0 0 15px; }.contact a { color: inherit; text-decoration: none; border-bottom: 2px solid; font-size: clamp(38px, 5vw, 73px); letter-spacing: -.08em; } footer { display: flex; justify-content: space-between; padding: 22px 0 32px; border-top: 1px solid; font-size: 11px; letter-spacing: .06em; } @media (max-width: 720px) { main { padding: 0 18px; } header { padding: 78px 0; } h1 { font-size: 72px; }.intro { margin: 0; font-size: 16px; }.project-grid { grid-template-columns: 1fr; }.project-card { padding: 18px 0 28px; }.project-card + .project-card { border-left: 0; }.cover { height: 265px; }.project-info h2 { min-height: 0; }.contact { padding: 90px 0; } footer { gap: 15px; font-size: 9px; } }
	.project-grid { grid-template-columns: repeat(3, minmax(0, 1fr)); gap: 18px; border-top: 0; }
	.project-card-wrap { position: relative; min-width: 0; }.project-card, .project-card + .project-card { display: block; min-width: 0; padding: 0; border: 0; }
	.cover { height: auto; aspect-ratio: 1 / .78; border: 0; }
	.project-info { padding: 14px 2px 4px; }
	.project-info h2 { min-height: 0; margin-bottom: 12px; font-size: clamp(24px, 2.2vw, 34px); }
	.cover img { width: 100%; height: 100%; object-fit: cover; }
	.project-add-card { display: grid; place-items: center; min-height: 0; aspect-ratio: 1 / .98; padding: 0; border: 1px dashed #9b9b9b; background: transparent; color: #4d4d4d; font-size: clamp(42px, 5vw, 70px); font-weight: 300; cursor: pointer; transition: background .2s, color .2s, border-color .2s; }.project-add-card:hover { border-color: #4d4d4d; background: #4d4d4d; color: #f4f4f4; }
	@media (max-width: 720px) { .project-grid { grid-template-columns: 1fr; gap: 28px; }.cover { height: auto; aspect-ratio: 1 / .72; }.project-card, .project-card + .project-card { padding: 0; border: 0; } }
	@media (min-width: 721px) { .project-card:nth-child(3n + 1) { border-left: 0; } }
	.card-edit { position: absolute; top: 9px; right: 9px; z-index: 2; padding: 6px 9px; border: 1px solid #4d4d4d; border-radius: 999px; background: #f4f4f4; color: #4d4d4d; font-size: 11px; cursor: pointer; }.card-edit:hover { background: #4d4d4d; color: #f4f4f4; }
	.local-editor { width: min(580px, calc(100% - 30px)); max-height: calc(100vh - 40px); padding: 0; border: 1px solid #4d4d4d; background: #f4f4f4; color: #4d4d4d; }.local-editor::backdrop { background: rgba(0,0,0,.42); }.local-editor form { display: grid; gap: 15px; padding: 24px; overflow-y: auto; }.editor-heading, .editor-actions { display: flex; justify-content: space-between; align-items: center; gap: 12px; }.editor-heading p { margin: 0; font-size: 12px; letter-spacing: .08em; }.editor-heading button { border: 0; background: transparent; font-size: 27px; cursor: pointer; }.local-editor label { display: grid; gap: 7px; font-size: 13px; }.local-editor small { color: #777; font-size: 11px; }.local-editor input, .local-editor textarea, .local-editor select { width: 100%; box-sizing: border-box; padding: 10px; border: 1px solid #9b9b9b; border-radius: 0; background: #fff; color: #1d1d1b; font: inherit; }.local-editor textarea { resize: vertical; }.new-project { justify-self: start; border: 0; padding: 0; background: transparent; color: inherit; text-decoration: underline; cursor: pointer; }.editor-actions { padding-top: 8px; }.editor-actions button { padding: 10px 14px; border: 1px solid #4d4d4d; background: transparent; color: inherit; cursor: pointer; }.editor-actions button[type='submit'] { background: #4d4d4d; color: #f4f4f4; }
	/* 首页统一主题覆盖 */
	html, body { background: #2c2c2c !important; color: #f4f4f4 !important; font-family: Futura, 'Futura PT', 'Helvetica Neue', Arial, sans-serif; }
	main { box-sizing: border-box; width: 100%; max-width: none; min-height: 100svh; margin: 0; padding: 70px 10.15vw 0; }
	nav { display: grid; grid-template-columns: 1fr auto auto auto; align-items: center; column-gap: clamp(30px, 5.9vw, 90px); margin-right: -4.8vw; padding: 0; border: 0; }
	nav .brand, nav a { color: #f2f2f2; font-size: 24px; font-weight: 400; line-height: 1; letter-spacing: -.04em; text-decoration: none; }
	nav a { color: #6f6f6f; transition: color 180ms ease; }
	nav a:hover, nav a:focus-visible, nav a.active { color: #f4f4f4; }
	header { padding-top: clamp(110px, 13vw, 190px); }
	header > p:first-child, .intro, .project-info p, .contact p { color: #a0a0a0; }
	h1, .project-info h2 { color: #f4f4f4; }
	.project-grid { border: 0; }
	.project-card { color: #f4f4f4; }
	.cover { border-color: #666; }
	.cover i, .cover b { border-color: #202020; }
	.tags span { border-color: #777; }
	.project-add-card { border-color: #777; color: #a0a0a0; }
	.project-add-card:hover { border-color: #f4f4f4; background: #f4f4f4; color: #2c2c2c; }
	.card-edit { border-color: #777; background: #2c2c2c; color: #f4f4f4; }
	.card-edit:hover { background: #f4f4f4; color: #2c2c2c; }
	.contact a { color: #f4f4f4; }
	footer { border-color: #666; color: #8a8a8a; }
	@media (max-width: 720px) {
		main { padding: 30px 24px 0; }
		nav { column-gap: 16px; margin-right: 0; }
		nav .brand, nav a { font-size: 16px; }
		nav a span { display: none; }
	}
</style>

<script>
	const editor = document.querySelector<HTMLDialogElement>('[data-list-editor]');
	if (editor) {
		const grid = document.querySelector<HTMLElement>('.project-grid')!;
		const key = 'local-project-list-v2';
		const defaults = Array.from(document.querySelectorAll<HTMLElement>('[data-project-card]')).map((card, index) => ({
			id: card.dataset.projectId ?? `project-${index}`,
			title: card.querySelector('h2')?.textContent ?? '',
			tags: Array.from(card.querySelectorAll('.tags span')).map((tag) => tag.textContent ?? ''),
			summary: card.querySelector('.project-info p')?.textContent ?? '',
			cover: card.querySelector<HTMLImageElement>('.cover img')?.getAttribute('src') ?? '',
			href: card.getAttribute('href') ?? '#',
			color: ['coral', 'blue', 'yellow'][index % 3],
		}));
		const openDatabase = () => new Promise<IDBDatabase>((resolve, reject) => {
			const request = indexedDB.open('portfolio-local-editor', 1);
			request.onupgradeneeded = () => request.result.createObjectStore('projects');
			request.onsuccess = () => resolve(request.result); request.onerror = () => reject(request.error);
		});
		const getItems = async () => {
			const database = await openDatabase();
			return await new Promise<any[] | undefined>((resolve, reject) => {
				const request = database.transaction('projects').objectStore('projects').get(key);
				request.onsuccess = () => resolve(request.result); request.onerror = () => reject(request.error);
			});
		};
		const saveItems = async (items: any[]) => {
			const database = await openDatabase();
			await new Promise<void>((resolve, reject) => {
				const request = database.transaction('projects', 'readwrite').objectStore('projects').put(items, key);
				request.onsuccess = () => resolve(); request.onerror = () => reject(request.error);
			});
		};
		const deleteItems = async () => {
			const database = await openDatabase();
			await new Promise<void>((resolve, reject) => {
				const request = database.transaction('projects', 'readwrite').objectStore('projects').delete(key);
				request.onsuccess = () => resolve(); request.onerror = () => reject(request.error);
			});
		};
		const appendAddCard = () => {
			const button = document.createElement('button');
			button.type = 'button'; button.className = 'project-add-card'; button.dataset.addCard = ''; button.setAttribute('aria-label', '增加新的项目'); button.textContent = '＋';
			grid.append(button);
		};
		const renderItems = (items: any[]) => {
			grid.innerHTML = '';
			items.forEach((item, index) => {
			const wrapper = document.createElement('div'); wrapper.className = 'project-card-wrap';
			const card = document.createElement('a'); card.className = `project-card ${item.color ?? ['coral', 'blue', 'yellow'][index % 3]}`; card.href = item.href || '#';
				const cover = document.createElement('div'); cover.className = 'cover';
				if (item.cover) { const image = document.createElement('img'); image.src = item.cover; image.alt = ''; cover.append(image); }
				else { cover.append(document.createElement('i'), document.createElement('b')); }
				const number = document.createElement('span'); number.textContent = String(index + 1).padStart(2, '0'); cover.append(number);
				const info = document.createElement('div'); info.className = 'project-info';
				const title = document.createElement('h2'); title.textContent = item.title || '未命名项目';
				const tags = document.createElement('div'); tags.className = 'tags'; (item.tags || []).filter(Boolean).forEach((tag: string) => { const pill = document.createElement('span'); pill.textContent = tag; tags.append(pill); });
				const summary = document.createElement('p'); summary.textContent = item.summary || '';
				info.append(title, tags, summary); card.append(cover, info); wrapper.append(card);
				const edit = document.createElement('button'); edit.type = 'button'; edit.className = 'card-edit'; edit.dataset.editCard = item.id; edit.textContent = '编辑'; wrapper.append(edit); grid.append(wrapper);
			});
			appendAddCard();
		};
		const form = editor.querySelector<HTMLFormElement>('[data-list-editor-form]')!;
		const select = form.querySelector<HTMLSelectElement>('[data-project-select]')!;
		let items = defaults;
		const fillSelect = () => { select.innerHTML = `${items.map((item) => `<option value="${item.id}">${item.title || '未命名项目'}</option>`).join('')}<option value="__new__">+ 增加新的项目</option>`; };
		const fillForm = () => {
			const item = items.find((entry) => entry.id === select.value) ?? items[0]; if (!item) return;
			(form.elements.namedItem('title') as HTMLInputElement).value = item.title ?? '';
			(form.elements.namedItem('tags') as HTMLInputElement).value = (item.tags ?? []).join(', ');
			(form.elements.namedItem('summary') as HTMLTextAreaElement).value = item.summary ?? '';
			(form.elements.namedItem('cover') as HTMLInputElement).value = '';
		};
		const readImage = (file: File) => new Promise<string>((resolve, reject) => { const reader = new FileReader(); reader.onload = () => resolve(String(reader.result)); reader.onerror = () => reject(reader.error); reader.readAsDataURL(file); });
		editor.querySelector<HTMLButtonElement>('[data-list-editor-close]')?.addEventListener('click', () => editor.close());
		const addProject = () => {
			const id = `local-${Date.now()}`;
			const item = { id, title: '新项目', tags: ['目标院校', '目标专业', '27FALL'], summary: '这是一个正在整理中的项目。你可以在这里补充项目背景、核心概念与最终成果。', cover: '', href: `/projects/local?id=${id}`, color: ['coral', 'blue', 'yellow'][items.length % 3] };
			items.push(item); renderItems(items); void saveItems(items); fillSelect(); select.value = item.id; fillForm();
		};
		grid.addEventListener('click', (event) => {
			const target = event.target as HTMLElement;
			if (target.closest('[data-add-card]')) { event.preventDefault(); addProject(); editor.showModal(); return; }
			const edit = target.closest<HTMLElement>('[data-edit-card]');
			if (!edit) return;
			event.preventDefault(); fillSelect(); select.value = edit.dataset.editCard ?? ''; fillForm(); editor.showModal();
		});
		editor.querySelector<HTMLButtonElement>('[data-delete-project]')?.addEventListener('click', async () => {
			const id = select.value; if (!id || !window.confirm('确定要删除这个项目吗？')) return;
			items = items.filter((item) => item.id !== id); await saveItems(items); renderItems(items); fillSelect(); fillForm();
		});
		select.addEventListener('change', () => select.value === '__new__' ? addProject() : fillForm());
		form.addEventListener('submit', async (event) => {
			event.preventDefault(); const formData = new FormData(form); const item = items.find((entry) => entry.id === select.value); if (!item) return;
			item.title = String(formData.get('title') ?? ''); item.tags = String(formData.get('tags') ?? '').split(',').map((tag) => tag.trim()).filter(Boolean); item.summary = String(formData.get('summary') ?? '');
			const image = formData.get('cover'); if (image instanceof File && image.size) item.cover = await readImage(image);
			await saveItems(items); renderItems(items); editor.close();
		});
		editor.querySelector<HTMLButtonElement>('[data-list-editor-reset]')?.addEventListener('click', async () => { await deleteItems(); items = defaults; renderItems(items); editor.close(); });
		getItems().then((saved) => {
			if (!saved?.length) return;
			items = saved.map((item) => ({
				...item,
				title: item.title || '新项目',
				tags: item.tags?.length ? item.tags : ['目标院校', '目标专业', '27FALL'],
				summary: item.summary || '这是一个正在整理中的项目。你可以在这里补充项目背景、核心概念与最终成果。',
			}));
			renderItems(items);
		}).catch(() => undefined);
	}
</script>
