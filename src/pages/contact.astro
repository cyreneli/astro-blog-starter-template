---
import BaseHead from '../components/BaseHead.astro';
---

<!doctype html>
<html lang="zh-CN">
	<head>
		<BaseHead title="Contact 联系 · Cyrene 文无" description="联系 Cyrene 文无。" />
	</head>
	<body>
		<main>
			<header class="site-header">
				<a class="brand" href="/">Cyrene 文无</a>
				<nav aria-label="主导航">
					<a href="/portfolio-coaching">Case <span>案例</span></a>
					<a href="/#about">Me <span>我</span></a>
					<a class="active" href="/contact">Contact <span>联系</span></a>
				</nav>
			</header>

			<section class="contact-intro" aria-labelledby="contact-title">
				<h1 id="contact-title">你可以通过下面的任何方式与我联系</h1>
				<p>Let’s connect — you can reach me in any of the ways below.</p>
			</section>

			<section class="contact-options" aria-label="联系方式">
				<a class="contact-item" href="https://www.xiaohongshu.com/" target="_blank" rel="noreferrer" aria-label="小红书">
					<span class="circle">
						<span class="xiaohongshu">小红书</span>
					</span>
					<span class="contact-name">Xiaohongshu</span>
				</a>
				<a class="contact-item" href="weixin://" aria-label="微信">
					<span class="circle">
						<span class="wechat" aria-hidden="true"><i></i><b></b></span>
					</span>
					<span class="contact-name">WeChat</span>
				</a>
				<a class="contact-item" href="https://www.behance.net/" target="_blank" rel="noreferrer" aria-label="Behance">
					<span class="circle">
						<span class="behance">Be</span>
					</span>
					<span class="contact-name">Behance</span>
				</a>
			</section>
		</main>
	</body>
</html>

<style>
	:global(html) { background: #2c2c2c !important; }
	:global(body) {
		margin: 0;
		background: #2c2c2c !important;
		color: #f4f4f4 !important;
		font-family: Futura, 'Futura PT', 'Helvetica Neue', Arial, sans-serif;
	}
	main {
		box-sizing: border-box;
		width: 100%;
		min-height: 100svh;
		padding: 86px 9.8vw 120px;
	}
	.site-header {
		display: flex;
		align-items: center;
		justify-content: space-between;
		margin-right: -4.8vw;
	}
	.brand, nav a {
		color: #6f6f6f;
		font-size: 24px;
		font-weight: 400;
		line-height: 1;
		letter-spacing: -0.04em;
		text-decoration: none;
	}
	nav { display: flex; gap: clamp(30px, 5.9vw, 90px); }
	nav a { transition: color 180ms ease; }
	nav a:hover, nav a:focus-visible, nav a.active { color: #f4f4f4; }
	.contact-intro {
		margin: clamp(260px, 21.8vw, 370px) auto 0;
		text-align: center;
	}
	h1, .contact-intro p {
		margin: 0;
		color: #707070;
		font-weight: 400;
		letter-spacing: -0.045em;
	}
	h1 { font-size: clamp(28px, 2.45vw, 40px); line-height: 1.25; }
	.contact-intro p { margin-top: 34px; font-size: clamp(27px, 2.45vw, 40px); line-height: 1.25; }
	.contact-options {
		display: flex;
		justify-content: center;
		gap: clamp(62px, 5.8vw, 104px);
		margin-top: clamp(130px, 10.5vw, 180px);
	}
	.contact-item { color: #f4f4f4; text-align: center; text-decoration: none; }
	.circle {
		display: grid;
		place-items: center;
		box-sizing: border-box;
		width: clamp(210px, 20.3vw, 290px);
		aspect-ratio: 1;
		border: 1px solid #747474;
		border-radius: 50%;
		background: #000;
		transition: transform 180ms ease, border-color 180ms ease;
	}
	.contact-item:hover .circle, .contact-item:focus-visible .circle {
		border-color: #f4f4f4;
		transform: scale(1.045);
	}
	.contact-name { display: block; margin-top: 14px; color: #777; font-size: 13px; opacity: 0; transition: opacity 180ms ease; }
	.contact-item:hover .contact-name, .contact-item:focus-visible .contact-name { opacity: 1; }
	.xiaohongshu {
		display: grid;
		place-items: center;
		width: 122px;
		height: 122px;
		border-radius: 8px;
		background: #2b2a43;
		color: white;
		font-size: 36px;
		font-weight: 700;
		letter-spacing: -0.08em;
	}
	.behance {
		display: grid;
		place-items: center;
		width: 148px;
		height: 148px;
		border-radius: 50%;
		background: #2b2a43;
		color: #000;
		font-family: Arial, sans-serif;
		font-size: 76px;
		font-weight: 700;
		letter-spacing: -0.1em;
	}
	.wechat { position: relative; display: block; width: 128px; height: 100px; }
	.wechat i, .wechat b { position: absolute; display: block; border-radius: 50%; background: #2b2a43; }
	.wechat i { top: 8px; left: 2px; width: 77px; height: 62px; }
	.wechat b { right: 0; bottom: 5px; width: 77px; height: 62px; }
	.wechat i::after, .wechat b::after {
		content: '';
		position: absolute;
		bottom: -10px;
		width: 20px;
		height: 24px;
		background: #2b2a43;
		clip-path: polygon(0 0, 100% 0, 20% 100%);
	}
	.wechat i::after { left: 12px; }
	.wechat b::after { right: 11px; transform: scaleX(-1); }
	.wechat::before, .wechat::after {
		content: '';
		position: absolute;
		z-index: 1;
		width: 9px;
		height: 9px;
		border-radius: 50%;
		background: #000;
	}
	.wechat::before { top: 28px; left: 28px; box-shadow: 31px 0 #000, 45px 30px #000; }
	.wechat::after { top: 58px; left: 76px; }
	@media (max-width: 720px) {
		main { padding: 30px 24px 60px; }
		.site-header { margin-right: 0; }
		.brand, nav a { font-size: 16px; }
		nav { gap: 16px; }
		nav a span { display: none; }
		.contact-intro { margin-top: 160px; }
		.contact-intro p { margin-top: 24px; }
		.contact-options { gap: 24px; margin-top: 88px; }
		.circle { width: 25vw; min-width: 92px; }
		.xiaohongshu { width: 54px; height: 54px; font-size: 16px; }
		.behance { width: 64px; height: 64px; font-size: 34px; }
		.wechat { transform: scale(.52); transform-origin: center; }
	}
</style>
