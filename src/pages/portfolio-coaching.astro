---
import BaseHead from '../components/BaseHead.astro';

const services = [
	{ number: '01', title: '作品集辅导', en: 'PORTFOLIO MENTORING', href: '/portfolio-projects', description: '从选题、项目叙事到最终呈现，一起梳理能够代表你思考方式的作品集。', items: ['方向与院校定位', '项目结构梳理', '叙事与呈现反馈'], color: 'coral' },
	{ number: '02', title: '排版辅导', en: 'EDITORIAL & LAYOUT', href: '/layout-projects', description: '让内容变得可读、好看且有节奏，建立一套经得起细看的版式系统。', items: ['信息层级', '网格与字体系统', '单页精修'], color: 'blue' },
	{ number: '03', title: '交互技术制作', en: 'INTERACTIVE PROTOTYPING', href: '/interactive-projects', description: '将概念做成可以被体验的原型，为网页、互动装置和数字作品提供技术支持。', items: ['网页与交互原型', '创意编程', '展览与技术呈现'], color: 'yellow' },
];
---

<!doctype html>
<html lang="zh-CN">
	<head><BaseHead title="作品集辅导 · Cyrene 文无" description="作品集、排版及交互技术辅导。" /></head>
	<body>
		<main>
			<nav aria-label="主导航">
				<a class="brand" href="/">Cyrene 文无</a>
				<div class="nav-links">
					<a class="active" href="/portfolio-coaching">Case <span>案例</span></a>
					<a href="/#about">Me <span>我</span></a>
					<a href="/contact">Contact <span>联系</span></a>
				</div>
			</nav>

			<section class="services" aria-label="辅导服务">
				{services.map((service) => (
					<a class:list={['service', service.color]} href={service.href}>
						<div class="service-meta"><span>{service.number}</span><span>{service.en}</span></div>
						<div class="art" aria-hidden="true"><i></i><b></b></div>
						<div class="service-body">
							<h1>{service.title}</h1>
							<p>{service.description}</p>
							<ul>{service.items.map((item) => <li>{item}</li>)}</ul>
							<span class="service-link">查看项目 <b>↗</b></span>
						</div>
					</a>
				))}
			</section>

			<section class="contact">
				<p>不确定该从哪里开始？</p>
				<h2>聊聊你的项目。</h2>
				<a href="/contact">预约咨询 <span>↗</span></a>
			</section>
			<footer><span>© 2026 CYRENE 文无</span><span>HANGZHOU / REMOTE</span></footer>
		</main>
	</body>
</html>

<style>
	:global(html) { background: #2c2c2c !important; }
	:global(body) { margin: 0; background: #2c2c2c !important; color: #f4f4f4 !important; font-family: Futura, 'Futura PT', 'Helvetica Neue', Arial, sans-serif; }
	main { box-sizing: border-box; width: 100%; min-height: 100svh; padding: 70px 10.15vw 0; }
	nav { display: flex; align-items: center; justify-content: space-between; margin-right: -4.8vw; }
	.brand, .nav-links a { color: #6f6f6f; font-size: 24px; font-weight: 400; line-height: 1; letter-spacing: -.04em; text-decoration: none; transition: color 180ms ease; }
	.nav-links { display: flex; gap: clamp(30px, 5.9vw, 90px); }
	.nav-links a:hover, .nav-links a:focus-visible, .nav-links .active { color: #f4f4f4; }
	.services { margin-top: clamp(120px, 13vw, 200px); border-top: 1px solid #656565; }
	.service { position: relative; display: grid; grid-template-columns: 16% 34% minmax(0, 1fr); gap: 28px; min-height: 400px; padding: 28px 0; border-bottom: 1px solid #656565; color: inherit; overflow: hidden; text-decoration: none; transition: background-color 200ms ease, padding 200ms ease; }
	.service:hover, .service:focus-visible { padding-inline: 16px; background: #353535; }
	.service-meta { display: flex; justify-content: space-between; color: #8a8a8a; font-size: 11px; letter-spacing: .06em; writing-mode: vertical-rl; transform: rotate(180deg); }
	.art { position: relative; align-self: center; height: 250px; }
	.art::before, .art i, .art b { position: absolute; display: block; content: ''; border: 2px solid #202020; transition: transform 300ms ease; }
	.coral .art::before { inset: 15px 18%; border-radius: 50% 50% 0 0; background: #ff8165; }.coral .art i { width: 68%; height: 42%; bottom: 15px; left: 15%; background: #f4f4f4; transform: rotate(-17deg); }.coral .art b { width: 29px; height: 29px; top: 68px; right: 23%; border-radius: 50%; background: #f5c94b; }
	.blue .art::before { width: 76%; height: 76%; top: 10%; left: 12%; background: #7195b8; transform: rotate(17deg); }.blue .art i { width: 55%; height: 55%; top: 22%; left: 24%; background: #f4f4f4; }.blue .art b { width: 32%; height: 32%; right: 0; bottom: 0; border-radius: 50%; background: #ff8165; }
	.yellow .art::before { width: 84%; height: 84%; top: 7%; left: 8%; border-radius: 50%; background: #f5c94b; }.yellow .art i { width: 2px; height: 108%; top: -4%; left: 50%; border: 0; background: #202020; transform: rotate(45deg); }.yellow .art b { width: 58px; height: 58px; top: 30%; left: 40%; border-radius: 50%; background: #d5e4e0; }
	.service:hover .art::before { transform: rotate(-14deg) scale(1.06); }.service:hover .art i { transform: rotate(24deg) translate(8px, -4px); }.service:hover .art b { transform: translate(10px, -7px) scale(1.15); }
	.service-body { align-self: end; max-width: 490px; padding-bottom: 7px; }
	.service-body h1, .contact h2 { margin: 0; color: #f4f4f4; font-weight: 400; letter-spacing: -.07em; }
	.service-body h1 { margin-bottom: 14px; font-size: clamp(40px, 5vw, 64px); line-height: 1; }
	.service-body p { margin: 0 0 23px; color: #b0b0b0; font-size: 16px; line-height: 1.55; }
	.service-body ul { display: flex; flex-wrap: wrap; gap: 8px; margin: 0; padding: 0; list-style: none; }.service-body li { padding: 5px 10px; border: 1px solid #777; border-radius: 30px; font-size: 12px; }
	.service-link { display: inline-block; margin-top: 22px; padding-bottom: 4px; border-bottom: 1px solid currentColor; font-size: 13px; }.service-link b { margin-left: 16px; font-size: 17px; font-weight: 400; }
	.contact { padding: 140px 0; }.contact p { margin: 0 0 10px; color: #a0a0a0; font-size: 15px; }.contact h2 { font-size: clamp(49px, 7vw, 100px); }.contact a { display: inline-block; margin-top: 38px; padding-bottom: 5px; border-bottom: 1px solid; color: #f4f4f4; font-size: 17px; text-decoration: none; }.contact a span { margin-left: 23px; font-size: 23px; }
	footer { display: flex; justify-content: space-between; padding: 22px 0 32px; border-top: 1px solid #656565; color: #858585; font-size: 11px; letter-spacing: .06em; }
	@media (max-width: 720px) { main { padding: 30px 24px 0; } nav { margin-right: 0; }.brand, .nav-links a { font-size: 16px; }.nav-links { gap: 16px; }.nav-links span { display: none; }.services { margin-top: 94px; }.service { grid-template-columns: 44px 1fr; min-height: 0; gap: 15px; padding: 20px 0 32px; }.service:hover { padding-inline: 7px; }.service-meta { grid-row: span 2; }.art { height: 210px; }.service-body { grid-column: 2; }.service-body h1 { font-size: 43px; }.contact { padding: 90px 0; } footer { gap: 16px; font-size: 9px; } }
</style>
