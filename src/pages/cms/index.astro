---
import BaseHead from '../../components/BaseHead.astro';
import { isAuthenticated, type CmsBindings } from '../../lib/cms';

export const prerender = false;
const authenticated = await isAuthenticated(Astro.request, Astro.locals.runtime.env as CmsBindings);
if (authenticated) return Astro.redirect('/portfolio-projects?cms=draft');
---

<!doctype html>
<html lang="zh-CN">
	<head><BaseHead title="CMS 登录 · Cyrene 文无" description="网站内容管理登录" /></head>
	<body>
		<main>
			<a class="brand" href="/">Cyrene 文无</a>
			<form data-login-form>
				<p>CONTENT MANAGEMENT</p>
				<h1>登录编辑</h1>
				<label>管理员密码<input name="password" type="password" autocomplete="current-password" required autofocus /></label>
				<button type="submit">登录</button>
				<p class="message" data-message aria-live="polite"></p>
			</form>
		</main>
	</body>
</html>

<style>
	:global(body) { margin: 0; background: #2c2c2c; color: #f4f4f4; font-family: Futura, 'Helvetica Neue', Arial, sans-serif; }
	main { min-height: 100svh; box-sizing: border-box; padding: 52px 10vw; }
	.brand { color: inherit; text-decoration: none; font-size: 22px; }
	form { display: grid; gap: 22px; width: min(460px, 100%); margin: 15vh auto 0; }
	form > p:first-child { margin: 0; color: #999; font-size: 12px; letter-spacing: .1em; }
	h1 { margin: 0 0 22px; font-size: clamp(54px, 8vw, 104px); font-weight: 400; line-height: .9; letter-spacing: -.08em; }
	label { display: grid; gap: 9px; font-size: 13px; }
	input { padding: 14px; border: 1px solid #777; background: #f4f4f4; color: #222; font: inherit; }
	button { padding: 14px; border: 1px solid #f4f4f4; background: #f4f4f4; color: #2c2c2c; font: inherit; cursor: pointer; }
	.message { min-height: 1.5em; margin: 0; color: #ff8165; }
</style>

<script>
	const form = document.querySelector<HTMLFormElement>('[data-login-form]')!;
	const message = document.querySelector<HTMLElement>('[data-message]')!;
	form.addEventListener('submit', async (event) => {
		event.preventDefault();
		message.textContent = '正在登录…';
		const response = await fetch('/api/cms/login', { method: 'POST', headers: { 'content-type': 'application/json' }, body: JSON.stringify({ password: new FormData(form).get('password') }) });
		const result = await response.json();
		if (!response.ok) { message.textContent = result.error || '登录失败'; return; }
		window.location.href = '/portfolio-projects?cms=draft';
	});
</script>
